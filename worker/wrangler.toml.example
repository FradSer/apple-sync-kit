name = "apple-sync-api"                 # your deployment name
main = "src/index.ts"
compatibility_date = "2026-03-01"

# The Worker is entity-agnostic: it serves exactly the tables listed in
# ENTITIES (validated against ^[a-z_][a-z0-9_]*$). The kit ships NO business
# migrations — each consumer CLI owns its own table schemas and migrations.
# Configure ENTITIES and migrations_dir to point at the consumer repo's
# migration directory.
#
# Example (note CLI — see note's skills/apple-notes/references/):
#   ENTITIES        = "notes,note_folders,note_preferences"
#   migrations_dir  = "<path-to-note>/skills/apple-notes/references/migrations"
#
# Shared note + event deployment: merge both consumers' migration directories
# into one dir (namespaced filenames like 0001_note_*, 0001_event_* avoid
# collisions in D1's d1_migrations table) and list every entity in ENTITIES.
# See each consumer's cloud-sync docs for the merge procedure.
[vars]
ENTITIES = "notes,note_folders,note_preferences"

# Point this at the consumer repo's migration directory (the one whose CREATE
# TABLE statements match the entities above). The kit does not provide it.
[[d1_databases]]
binding = "DB"
database_name = "apple-sync"             # your D1 database name
database_id = "REPLACE_WITH_YOUR_DATABASE_ID"
migrations_dir = "REPLACE_WITH_CONSUMER_MIGRATIONS_DIR"

# Daily purge of soft-deleted records older than 30 days.
[triggers]
crons = ["0 3 * * *"]
